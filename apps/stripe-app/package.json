{
  "name": "@riposte/stripe-app",
  "version": "0.0.1",
  "private": true,
  "description": "Riposte Stripe App manifest",
  "license": "AGPL-3.0-only",
  "scripts": {
    "prepare-package": "npm install --package-lock-only --ignore-scripts",
    "prepare-upload": "node scripts/prepare-upload.mjs",
    "typecheck": "tsc --noEmit",
    "upload": "npm run prepare-package && npm run prepare-upload -- stripe-app.json .build/upload/prod && stripe -p riposte apps upload .build/upload/prod",
    "start": "stripe -p riposte apps start --manifest stripe-app.json"
  },
  "dependencies": {
    "@stripe/ui-extension-sdk": "9.1.0",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.28"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
