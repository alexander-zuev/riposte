{
  "name": "@riposte/stripe-app",
  "version": "0.0.1",
  "description": "Riposte Stripe App manifest",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare-package": "npm install --package-lock-only --ignore-scripts",
    "typecheck": "tsc --noEmit",
    "upload": "npm install --package-lock-only --ignore-scripts && stripe apps upload",
    "start": "stripe apps start --manifest stripe-app.dev.json"
  },
  "dependencies": {
    "@stripe/ui-extension-sdk": "9.1.0",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.28"
  }
}
