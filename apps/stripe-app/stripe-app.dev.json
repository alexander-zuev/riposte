{
  "extends": "stripe-app.json",
  "id": "app.dev.riposte.sh",
  "name": "Riposte Dev",
  "version": "0.0.1",
  "distribution_type": "private",
  "ui_extension": {
    "content_security_policy": {
      "connect-src": [
        "https://tunnel.riposte.sh/api/stripe/app/settings",
        "https://tunnel.riposte.sh/api/stripe/app/sync"
      ],
      "purpose": "Allow local development settings to call the Riposte tunnel backend"
    }
  },
  "constants": {
    "API_BASE": "https://tunnel.riposte.sh"
  },
  "post_install_action": {
    "type": "external",
    "url": "https://tunnel.riposte.sh/settings"
  },
  "allowed_redirect_uris": ["https://tunnel.riposte.sh/api/stripe/oauth/callback"]
}
