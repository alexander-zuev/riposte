# =============================================================================
# CLIENT — Build-time variables (VITE_ prefix, baked into JS bundle by Vite)
# =============================================================================

# App URL
# Local: http://localhost:3000 | Preview: https://preview.riposte.dev | Prod: https://riposte.dev
VITE_APP_URL=http://localhost:3000

# Sentry (client-side DSN) — same DSN across all envs
VITE_SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/123456

# Sentry Auth Token — for uploading source maps during build
SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token

# PostHog — same key across all envs
VITE_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# =============================================================================
# SERVER — Secrets (read by Cloudflare Worker via env.*)
# =============================================================================

# Better Auth — generate secret with `openssl rand -base64 32`
BETTER_AUTH_SECRET=your-better-auth-secret
