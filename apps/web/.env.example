# =============================================================================
# CLIENT — Build-time variables (VITE_ prefix, baked into JS bundle by Vite)
# =============================================================================

# App URL
# Local: http://localhost:3000 | Preview: https://preview.riposte.dev | Prod: https://riposte.dev
VITE_APP_URL=http://localhost:3000

# Sentry (client-side DSN) — same DSN across all envs
VITE_SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/123456

# Sentry Auth Token — for uploading source maps during build
SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token

# PostHog — same key across all envs
VITE_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# =============================================================================
# SERVER — Secrets (read by Cloudflare Worker via env.*)
# =============================================================================

# Better Auth — generate secret with `openssl rand -base64 32`
BETTER_AUTH_SECRET=your-better-auth-secret

# OAuth — Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth — GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Captcha — Cloudflare Turnstile
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Stripe
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_TEST_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
STRIPE_APP_WEBHOOK_SECRET=whsec_dummy

# Credential encryption — generate key with `openssl rand -base64 32`
CURRENT_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1
CREDENTIAL_ENCRYPTION_KEY_V1=your-base64-32-byte-key

# Email — Resend
RESEND_API_KEY=re_dummy
