{
  "name": "@riposte/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types --env dev",
    "dev": "CLOUDFLARE_ENV=dev dotenvx run -- vite",
    "build": "CLOUDFLARE_ENV=preview vite build --mode preview && oxlint src --quiet && tsc -p tsconfig.build.json --noEmit",
    "build:prod": "CLOUDFLARE_ENV=prod vite build --mode production && oxlint src --quiet && tsc -p tsconfig.build.json --noEmit",
    "typecheck": "tsc --noEmit",
    "preview": "dotenvx run -- vite preview",
    "test": "vitest run --reporter=dot --silent",
    "test:unit": "vitest run --reporter=dot --silent",
    "test:verbose": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src --quiet",
    "lint:fix": "oxlint src --fix --quiet",
    "storybook": "dotenvx run -- storybook dev -p 6006",
    "build-storybook": "dotenvx run -- storybook build",
    "deploy": "wrangler deploy --env preview --minify",
    "deploy:prod": "wrangler deploy --env prod --minify",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "wrangler d1 migrations apply RIPOSTE_D1 --local --env dev",
    "db:migrate:preview": "wrangler d1 migrations apply RIPOSTE_D1 --remote --env preview",
    "db:migrate:prod": "wrangler d1 migrations apply RIPOSTE_D1 --remote --env prod",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@cloudflare/vite-plugin": "catalog:",
    "@fontsource-variable/jetbrains-mono": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "@sentry/cloudflare": "catalog:",
    "@sentry/tanstackstart-react": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@tanstack/zod-adapter": "catalog:",
    "@riposte/core": "workspace:*",
    "better-auth": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "drizzle-orm": "catalog:",
    "motion": "catalog:",
    "next-themes": "catalog:",
    "posthog-js": "catalog:",
    "posthog-node": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "catalog:",
    "shadcn": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "catalog:",
    "@sentry/vite-plugin": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "better-sqlite3": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "jsdom": "catalog:",
    "storybook": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
