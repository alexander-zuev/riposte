{
  "name": "riposte",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev --ui=stream",
    "build": "turbo run build",
    "build:prod": "turbo run build:prod",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "storybook": "pnpm --filter @riposte/web run storybook",
    "deploy": "pnpm --filter @riposte/web run deploy",
    "deploy:prod": "pnpm --filter @riposte/web run deploy:prod",
    "db:generate": "pnpm --filter @riposte/web run db:generate",
    "db:migrate:dev": "pnpm --filter @riposte/web run db:migrate:dev",
    "db:migrate:preview": "pnpm --filter @riposte/web run db:migrate:preview",
    "db:migrate:prod": "pnpm --filter @riposte/web run db:migrate:prod",
    "db:studio": "pnpm --filter @riposte/web run db:studio"
  },
  "devDependencies": {
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.{json,jsonc,yaml,yml,md,css}": [
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.0.3"
}
