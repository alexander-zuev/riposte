{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@core/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types", "node"],
    "allowImportingTsExtensions": false,
    "declaration": true,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src"]
}
